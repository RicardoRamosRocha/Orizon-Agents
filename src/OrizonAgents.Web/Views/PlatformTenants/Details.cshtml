@model TenantDetailsDto
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = Model.Name;
    ViewData["Section"] = "Plataforma";
}

@if (TempData["StatusMessage"] is string statusMessage)
{
    <div class="alert alert-success">@statusMessage</div>
}
@if (TempData["ErrorMessage"] is string errorMessage)
{
    <div class="alert alert-danger">@errorMessage</div>
}

<section class="admin-hero">
    <div>
        <p class="eyebrow">@Model.Slug</p>
        <h2>@Model.Name</h2>
        <p class="muted">@Model.Culture · @Model.TimeZone</p>
    </div>
    <span class="status-badge status-badge--@Model.Status.ToLowerInvariant()">@Model.Status</span>
</section>

<section class="metric-grid">
    <article class="metric-card metric-card--primary"><span>Usuários</span><strong>@Model.TotalUsers</strong><small>Total cadastrado</small></article>
    <article class="metric-card metric-card--success"><span>Ativos</span><strong>@Model.ActiveUsers</strong><small>Contas habilitadas</small></article>
    <article class="metric-card metric-card--violet"><span>Admins</span><strong>@Model.AdminUsers</strong><small>TenantAdmins</small></article>
    <article class="metric-card metric-card--warning"><span>Criada em</span><strong>@Model.CreatedAtUtc.ToLocalTime().ToString("dd/MM")</strong><small>@Model.CreatedAtUtc.ToLocalTime().ToString("yyyy")</small></article>
</section>

<section class="admin-grid">
    <article class="admin-card">
        <div class="card-heading">
            <div>
                <h3>Dados e contato</h3>
                <p>Informações principais da organização.</p>
            </div>
            <a asp-action="Edit" asp-route-id="@Model.Id">Editar</a>
        </div>
        <dl class="details-list">
            <dt>Contato</dt><dd>@(Model.ContactName ?? "Não informado")</dd>
            <dt>E-mail</dt><dd>@(Model.ContactEmail ?? "Não informado")</dd>
            <dt>Telefone</dt><dd>@(Model.ContactPhone ?? "Não informado")</dd>
            <dt>Atualizada em</dt><dd>@(Model.UpdatedAtUtc?.ToLocalTime().ToString("dd/MM/yyyy HH:mm") ?? "Sem atualização")</dd>
        </dl>
    </article>

    <article class="admin-card">
        <h3>Status operacional</h3>
        @if (Model.Status == "Suspended")
        {
            <p class="muted">Suspensa em @Model.SuspendedAtUtc?.ToLocalTime().ToString("dd/MM/yyyy HH:mm"). Motivo registrado para auditoria:</p>
            <p>@Model.SuspensionReason</p>
            <form asp-action="Reactivate" asp-route-id="@Model.Id" method="post">
                <input type="hidden" name="concurrencyStamp" value="@Model.ConcurrencyStamp" />
                <button type="submit" class="btn btn-primary">Reativar organização</button>
            </form>
        }
        else
        {
            <p class="muted">Organização ativa para operação normal.</p>
            <a class="btn btn-outline-danger" asp-action="Suspend" asp-route-id="@Model.Id">Suspender</a>
        }
    </article>
</section>

<section class="admin-card">
    <h3>Usuários recentes</h3>
    @if (Model.RecentUsers.Count == 0)
    {
        <div class="empty-state">Nenhum usuário recente.</div>
    }
    else
    {
        <div class="user-list">
            @foreach (var user in Model.RecentUsers)
            {
                <div class="user-row">
                    <span class="avatar">@(string.IsNullOrWhiteSpace(user.FullName) ? "U" : user.FullName[..1].ToUpperInvariant())</span>
                    <div>
                        <strong>@user.FullName</strong>
                        <p>@user.Email</p>
                    </div>
                    <span class="status-dot @(user.IsActive ? "active" : "")"></span>
                </div>
            }
        </div>
    }
</section>
