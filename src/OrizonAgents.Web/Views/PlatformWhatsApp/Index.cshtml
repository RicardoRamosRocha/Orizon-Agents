@model OrizonAgents.Application.WhatsApp.Models.WhatsAppPlatformOverviewDto
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "WhatsApp da plataforma";
    ViewData["Section"] = "PlatformAdmin";
}

<section class="admin-hero">
    <div><p class="eyebrow">Operação WhatsApp</p><h2>Estado técnico agregado</h2><p class="muted">Sem tokens ou conteúdo privado desnecessário.</p></div>
</section>

<section class="metric-grid">
    <article class="metric-card metric-card--primary"><span>Conexões</span><strong>@Model.TotalConnections</strong><small>@Model.ActiveConnections ativas</small></article>
    <article class="metric-card metric-card--warning"><span>Eventos pendentes</span><strong>@Model.PendingInboxEvents</strong><small>Inbox aguardando worker</small></article>
    <article class="metric-card metric-card--violet"><span>Dead letters</span><strong>@Model.DeadLetters</strong><small>Falhas permanentes</small></article>
    <article class="metric-card metric-card--success"><span>Mensagens</span><strong>@Model.ProcessedMessages</strong><small>@Model.FailedMessages com falha</small></article>
</section>

<article class="admin-card">
    <div class="card-heading"><div><h3>Conexões recentes</h3><p>Estado técnico por tenant.</p></div></div>
    @if (Model.RecentConnections.Count == 0)
    {
        <div class="empty-state">Nenhuma conexão registrada.</div>
    }
    else
    {
        <div class="table-wrap"><table><thead><tr><th>Tenant</th><th>Nome</th><th>Número</th><th>Status</th><th>Qualidade</th><th>Webhook</th></tr></thead><tbody>
        @foreach (var connection in Model.RecentConnections)
        {
            <tr><td>@connection.TenantId</td><td>@connection.Name</td><td>@connection.DisplayPhoneNumber</td><td>@connection.Status</td><td>@connection.QualityRating</td><td>@connection.LastWebhookAtUtc</td></tr>
        }
        </tbody></table></div>
    }
</article>
