@model IReadOnlyCollection<UserAccountDto>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Usuários";
    ViewData["Section"] = "Organização";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="h4 mb-1">Usuários da organização</h1>
        <p class="text-muted mb-0">Gerencie apenas contas do seu tenant.</p>
    </div>
    <a class="btn btn-primary" asp-action="Create">Novo usuário</a>
</div>
@if (TempData["StatusMessage"] is string message)
{
    <div class="alert alert-info">@message</div>
}
<form method="get" class="mb-3">
    <div class="input-group">
        <input name="search" value="@ViewData["Search"]" class="form-control" placeholder="Pesquisar por nome ou e-mail" />
        <button type="submit" class="btn btn-outline-secondary">Pesquisar</button>
    </div>
</form>
<div class="table-responsive border rounded bg-white">
    <table class="table align-middle mb-0">
        <thead>
            <tr>
                <th>Nome</th>
                <th>E-mail</th>
                <th>Papel</th>
                <th>Status</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
        @foreach (UserAccountDto user in Model)
        {
            <tr>
                <td>@user.FullName</td>
                <td>@user.Email</td>
                <td>@string.Join(", ", user.Roles)</td>
                <td>@(user.IsActive ? "Ativo" : "Inativo")</td>
                <td class="text-end">
                    <a class="btn btn-sm btn-outline-secondary" asp-action="Edit" asp-route-id="@user.Id">Editar</a>
                    <a class="btn btn-sm btn-outline-secondary" asp-action="ResetPassword" asp-route-id="@user.Id">Senha</a>
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>
