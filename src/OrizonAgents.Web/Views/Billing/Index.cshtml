@model TenantBillingDto
@{ Layout = "_AdminLayout"; ViewData["Title"] = "Meu plano"; ViewData["Section"] = "Billing"; }
<section class="admin-hero"><div><p class="eyebrow">Assinatura atual</p><h2>@Model.Subscription.PlanName</h2><p class="muted">@Model.Subscription.Status · @Model.Subscription.BillingCycle</p></div><span class="status-badge">@Model.Subscription.Status</span></section>
<section class="admin-card"><h3>Utilização e limites</h3>@foreach(var usage in Model.Subscription.Usage){<div class="usage-row"><strong>@usage.FeatureKey</strong><progress max="@(usage.LimitValue ?? Math.Max(usage.Used, 1))" value="@usage.Used"></progress><span>@usage.Used / @(usage.IsUnlimited ? "Ilimitado" : usage.LimitValue)</span></div>}</section>
<section class="admin-card"><h3>Planos públicos disponíveis</h3><p class="muted">Solicitação de alteração de plano estará disponível quando um gateway de cobrança real for configurado. Nenhuma cobrança é simulada nesta tela.</p><div class="plan-grid">@foreach(var plan in Model.PublicPlans){<article class="admin-card plan-card"><h3>@plan.Name</h3><p>@plan.Currency @plan.MonthlyPrice.ToString("0.00")/mês</p><span class="status-badge">Solicitação indisponível</span></article>}</div></section>
<section class="admin-card"><h3>Histórico</h3>@foreach(var item in Model.History){<div class="setup-item is-complete"><span></span><div><strong>@item.Event</strong><p>@item.Description</p></div></div>}</section>
